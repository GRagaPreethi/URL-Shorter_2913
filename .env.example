# Postgres connection string used by the API server and Drizzle migrations
DATABASE_URL=postgresql://user:password@localhost:5432/linksnap

# Port the API server listens on
PORT=8080

# Optional: base path prefix for the frontend when served behind a proxy
BASE_PATH=/

# Optional: pino log level (e.g. info, debug, warn)
LOG_LEVEL=info

# Optional: enables AI-generated alias suggestions via Google Gemini.
# If unset or invalid, alias suggestions fall back to a deterministic
# rule-based generator automatically.
GEMINI_API_KEY=

NODE_ENV=development
